# JLPT Master 环境配置
# 复制此文件为 .env 并填入实际值

# AI 服务（必填）
LLM_PROVIDER=gemini          # gemini | openai | ollama
LLM_MODEL=gemini-2.0-flash
LLM_API_KEY=your_api_key_here

# 学习目标级别
TARGET_LEVEL=N2              # N1 | N2 | N3 | N4 | N5

# 向量模型（首次启动自动下载，约 570MB）
EMBEDDING_MODEL=BAAI/bge-m3

# 数据库（Docker 内部自动配置，本地开发时取消注释）
# DATABASE_URL=postgresql+asyncpg://jlpt:jlpt@localhost:5432/jlpt
# QDRANT_URL=http://localhost:6333

# 本地开发时覆盖 JMdict 路径（Docker 内部自动正确）
# JMDICT_PATH=/Users/你的用户名/JLPT-master/backend/data/JMdict_e.xml
